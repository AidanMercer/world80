                    Repeater {
                        model: root.themeSlots

                        delegate: Rectangle {
                            id: slotRow
                            required property int index
                            required property var modelData
                            readonly property int rowIdx: 2 + index
                            readonly property bool isOn: ThemeSettings.on(root.themeDirNow, modelData.slot)

