                                Column {
                                    anchors.centerIn: parent
                                    width: parent.width
                                    spacing: 6
                                    visible: erow.busy
                                    Text {
                                        anchors.horizontalCenter: parent.horizontalCenter
                                        text: erow.prog ? ((erow.st.installed ? "updating " : "installing ")
