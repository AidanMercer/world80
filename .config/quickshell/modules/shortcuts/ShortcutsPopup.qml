                                anchors.right: mktAction.left
                                anchors.rightMargin: 14
                                anchors.verticalCenter: parent.verticalCenter
                                spacing: 5

                                Row {
                                    spacing: 8
                                    Text {
                                        anchors.verticalCenter: parent.verticalCenter
                                        text: mrow.modelData.name
                                        color: Theme.textBright
                                        font.pixelSize: 15
                                        font.weight: Font.DemiBold
                                    }
                                    Row {
                                        anchors.verticalCenter: parent.verticalCenter
